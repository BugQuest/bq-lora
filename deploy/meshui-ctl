#!/bin/sh
# Helper privilegie pour meshui : seules ces operations sont autorisees via
# sudo NOPASSWD (cf. /etc/sudoers.d/meshui). Garder cette surface reduite.
set -e
case "$1" in
    reboot)
        exec /sbin/reboot
        ;;
    poweroff)
        exec /sbin/poweroff
        ;;
    ssh-on)
        systemctl enable ssh
        systemctl start ssh
        ;;
    ssh-off)
        systemctl stop ssh
        systemctl disable ssh
        ;;
    restart-meshui)
        exec systemctl restart meshui
        ;;
    hotspot-on)
        SSID="${2:-BugQuest-Lora}"
        PASS="${3:-bugquest-lora}"
        /usr/bin/nmcli connection up Hotspot 2>/dev/null \
            || exec /usr/bin/nmcli device wifi hotspot ifname wlan0 ssid "$SSID" password "$PASS"
        ;;
    hotspot-off)
        exec /usr/bin/nmcli connection down Hotspot
        ;;
    backlight)
        # $2 = duty 0..1000000 (la PWM tourne a 1 kHz / periode 1 ms)
        echo "${2:-1000000}" > /sys/class/pwm/pwmchip0/pwm0/duty_cycle
        ;;
    timezone)
        exec /usr/bin/timedatectl set-timezone "$2"
        ;;
    wifi-on)
        exec /usr/bin/nmcli radio wifi on
        ;;
    wifi-off)
        exec /usr/bin/nmcli radio wifi off
        ;;
    bt-on)
        /usr/sbin/rfkill unblock bluetooth || true
        systemctl start bluetooth.service 2>/dev/null || true
        ;;
    bt-off)
        systemctl stop meshui-btserial 2>/dev/null || true
        exec /usr/sbin/rfkill block bluetooth
        ;;
    bt-scan)
        # Decouverte BLE/Classic. Sortie : MAC|NOM|RSSI|paired|connected|
        # RSSI fourni par btmgmt (live), noms/etats par bluetoothctl (cache).
        SECS="${2:-8}"
        # Bluetooth demarre a la demande (desactive au boot pour gagner du temps)
        systemctl start bluetooth.service 2>/dev/null || true
        /usr/sbin/rfkill unblock bluetooth 2>/dev/null || true
        /usr/bin/bluetoothctl --timeout 1 power on >/dev/null 2>&1 || true
        TMP=$(mktemp)
        timeout $((SECS + 3)) /usr/bin/btmgmt find 2>/dev/null | awk '
            /dev_found:/ { mac=$3; r=""; for(i=1;i<=NF;i++) if($i=="rssi") r=$(i+1);
                           if(!(mac in seen)){seen[mac]=1; order[++k]=mac}; rssi[mac]=r }
            /^name / { n=$0; sub(/^name /,"",n); name[mac]=n }
            END { for(i=1;i<=k;i++){m=order[i]; printf "%s\t%s\t%s\n", m, rssi[m], name[m]} }
        ' > "$TMP"
        paired=$(/usr/bin/bluetoothctl devices Paired 2>/dev/null | awk '{print $2}')
        conn=$(/usr/bin/bluetoothctl devices Connected 2>/dev/null | awk '{print $2}')
        is_in() { printf '%s\n' "$2" | grep -qi "$1"; }
        # 1) appareils deja appaires en premier (avec RSSI s'ils ont ete revus)
        for m in $paired; do
            nm=$(/usr/bin/bluetoothctl info "$m" 2>/dev/null | sed -n 's/^[[:space:]]*Name: //p' | head -n1)
            [ -z "$nm" ] && nm="$m"
            r=$(awk -F'\t' -v M="$m" 'toupper($1)==toupper(M){print $2; exit}' "$TMP")
            c=0; is_in "$m" "$conn" && c=1
            printf '%s|%s|%s|1|%s|\n' "$m" "$nm" "${r:-0}" "$c"
        done
        # 2) appareils decouverts non appaires
        while IFS="$(printf '\t')" read -r mac rssi nm; do
            [ -z "$mac" ] && continue
            is_in "$mac" "$paired" && continue
            if [ -z "$nm" ]; then
                nm=$(/usr/bin/bluetoothctl info "$mac" 2>/dev/null | sed -n 's/^[[:space:]]*Name: //p' | head -n1)
                [ -z "$nm" ] && nm="$mac"
            fi
            printf '%s|%s|%s|0|0|\n' "$mac" "$nm" "${rssi:-0}"
        done < "$TMP"
        rm -f "$TMP"
        ;;
    bt-pair)
        # Appairage "Just Works" (NoInputNoOutput) + trust + connect, mac=$2
        mac="$2"
        /usr/bin/bluetoothctl --timeout 25 <<EOF
power on
agent NoInputNoOutput
default-agent
pairable on
pair $mac
trust $mac
connect $mac
EOF
        ;;
    bt-connect)
        exec /usr/bin/bluetoothctl connect "$2"
        ;;
    bt-disconnect)
        exec /usr/bin/bluetoothctl disconnect "$2"
        ;;
    bt-remove)
        exec /usr/bin/bluetoothctl remove "$2"
        ;;
    bt-serial-on)
        # Console serie SPP (RFCOMM canal 1) : rend le Pi appairable/visible + lance le service
        /usr/sbin/rfkill unblock bluetooth 2>/dev/null || true
        /usr/bin/bluetoothctl --timeout 2 <<EOF >/dev/null 2>&1 || true
power on
discoverable-timeout 0
discoverable on
pairable on
EOF
        systemctl start meshui-btserial
        ;;
    bt-serial-off)
        systemctl stop meshui-btserial 2>/dev/null || true
        printf 'discoverable off\nquit\n' | /usr/bin/bluetoothctl >/dev/null 2>&1 || true
        ;;
    bt-serial-status)
        systemctl is-active meshui-btserial 2>/dev/null || echo inactive
        ;;
    usb-hid)
        exec /usr/local/sbin/meshui-usb-hid
        ;;
    usb-ncm)
        exec /usr/local/sbin/meshui-usb-gadget
        ;;
    usb-storage)
        exec /usr/local/sbin/meshui-usb-storage
        ;;
    update)
        exec /usr/local/sbin/meshui-update
        ;;
    usb-net-share)
        # Pi = serveur DHCP/passerelle sur usb0 (10.42.1.1).
        # Sous-reseau distinct du hotspot WiFi (10.42.0.1) pour eviter la
        # collision quand les deux sont actifs en meme temps.
        /usr/bin/nmcli connection modify usb0 ipv4.method shared ipv4.addresses 10.42.1.1/24 ipv6.method ignore
        exec /usr/bin/nmcli connection up usb0
        ;;
    usb-net-client)
        # Pi = client DHCP sur usb0 (recoit l'IP depuis l'ICS Windows / PC partage)
        /usr/bin/nmcli connection modify usb0 ipv4.method auto ipv4.addresses "" ipv6.method auto
        exec /usr/bin/nmcli connection up usb0
        ;;
    wifi-scan)
        exec /usr/bin/nmcli -t -f IN-USE,SSID,SIGNAL,SECURITY device wifi list --rescan yes
        ;;
    wifi-connect)
        # $2 = SSID, $3 = passphrase (peut etre vide pour reseau ouvert)
        if [ -z "$3" ]; then
            exec /usr/bin/nmcli device wifi connect "$2"
        else
            exec /usr/bin/nmcli device wifi connect "$2" password "$3"
        fi
        ;;
    *)
        echo "usage: $0 {reboot|poweroff|ssh-on|ssh-off|wifi-scan|wifi-connect SSID [PASS]|bt-scan|bt-pair MAC|bt-connect MAC|bt-remove MAC|bt-serial-on|bt-serial-off}" >&2
        exit 2
        ;;
esac
